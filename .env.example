# Copy this file to .env and fill in your token. Loaded at startup by
# python-dotenv. For the systemd service these are set in the unit file
# (deploy/hug-face-rip.service) instead of here.

# --- Required ---

# Hugging Face access token: https://huggingface.co/settings/tokens
# Needs read access to the repos you back up (required even for public repos).
HUGGINGFACE_ACCESS_KEY=hf_your_token_here

# Where backups are written. Created if missing; must be writable. Each repo
# lands in BACKUP_DIR/<repo_type>s/<owner>/<name>. Absolute or relative path.
BACKUP_DIR=./backups

# --- Optional (defaults shown) ---

# How many repos download at once.
MAX_CONCURRENT_JOBS=2

# How many files download in parallel within each repo. Peak RAM scales with
# MAX_CONCURRENT_JOBS x MAX_WORKERS -- lower both on a small / low-RAM host.
MAX_WORKERS=8

# SQLite job-database path (stores the queue + progress).
DB_PATH=jobs.db

# Verify every finished download against Hugging Face's reported hashes (SHA256
# for LFS weights, git-blob-SHA1 for plain files) before showing it as done.
# Set 0 to skip the post-download hash pass on slow / very large-repo hosts;
# the manual Verify button on the dashboard always works regardless.
VERIFY_DOWNLOADS=1

# Stall watchdog: if a running download writes no new bytes to disk for this many
# seconds, the child is terminated and the job is retried (with backoff, partial
# files kept). Guards against a half-dead connection hanging a download — and the
# whole queue behind it — forever with no error. Set 0 to disable.
STALL_TIMEOUT_SECONDS=600

# Bind address. 0.0.0.0 exposes the unauthenticated dashboard to the network;
# use 127.0.0.1 to restrict it to this machine.
# HOST=0.0.0.0
# PORT=8000

# Hugging Face Xet downloader memory knobs (see README, "Tuning for memory"):
# HF_HUB_DISABLE_XET=1                # plain HTTP, near-constant memory (small hosts)
# HF_XET_NUM_CONCURRENT_RANGE_GETS=8  # or cap Xet concurrency instead of disabling
